{
  "name": "magic-i18next",
  "version": "1.0.0",
  "description": "自动化脚本, 再利用i18n完成国际化多语言项目",
  "main": "build/index.js",
  "types": "build/types/src/main.d.ts",
  "type": "module",
  "bin": {
    "magic": "build/cli.js",
    "magic-i18next": "build/cli.js",
    "magic-i18next-rep": "build/conversion/index.js",
    "magic-i18next-excel": "build/json2Excel/index.js",
    "magic-i18next-json": "build/excel2Json/index.js"
  },
  "scripts": {
    "test": "tsx test.ts",
    "lint": "tsc -p tsconfig.lint.json && eslint src",
    "push": "tsx src/cli.ts push:feishu",
    "pull": "tsx src/cli.ts pull:feishu",
    "push:google": "tsx src/cli.ts push:google",
    "pull:google": "tsx src/cli.ts pull:google",
    "translate": "tsx src/cli.ts translate",
    "push-test": "tsx src/feishu/test.ts",
    "build": "rimraf build && rollup -c rollup.config.mjs --bundleConfigAsCjs && rollup -c rollup.config.cli.mjs --bundleConfigAsCjs",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "homepage": "https://magic-i18next.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/ephemeral98/magic-i18next"
  },
  "keywords": [
    "i18n",
    "i18next",
    "vue-i18n",
    "react-i18next",
    "international"
  ],
  "author": "",
  "license": "ISC",
  "files": [
    "build",
    "README.md"
  ],
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/plugin-transform-runtime": "^7.26.9",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-typescript": "^7.26.9",
    "@eslint/js": "^9.21.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-strip": "^3.0.4",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^20.17.0",
    "core-js": "^3.38.1",
    "eslint": "^9.21.0",
    "nodemon": "^3.1.7",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-delete": "^2.0.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-serve": "^2.0.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.25.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "google-auth-library": "^10.6.2",
    "google-spreadsheet": "^5.2.0",
    "https-proxy-agent": "^8.0.0",
    "jiti": "^2.6.1",
    "undici": "^7.24.4",
    "xlsx": "^0.18.5"
  }
}
